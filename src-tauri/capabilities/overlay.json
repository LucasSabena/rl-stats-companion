{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "overlay",
  "description": "Capabilities for the transparent overlay window",
  "windows": ["overlay"],
  "permissions": [
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-set-size",
    "core:window:allow-set-position"
  ]
}
